{% extends 'layouts/app.html.twig' %}

{% block title %}Planificateur de repas - WellCare Connect{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('nutrition-css') }}
{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <!-- Recipe Selection Modal -->
    <div id="recipe-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50">
        <div class="flex items-center justify-center min-h-screen p-4">
            <div class="bg-white dark:bg-gray-800 rounded-2xl max-w-4xl w-full max-h-[90vh] overflow-hidden">
                <div class="p-6 border-b border-gray-200 dark:border-gray-700">
                    <div class="flex items-center justify-between">
                        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Sélectionner une recette</h2>
                        <button onclick="closeRecipeModal()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
                            <i class="fas fa-times text-xl"></i>
                        </button>
                    </div>
                    <div class="mt-4">
                        <input type="text" id="recipe-search" placeholder="Rechercher une recette..."
                               class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-wellcare-500 focus:border-transparent dark:bg-gray-700 dark:text-white">
                    </div>
                </div>
                <div class="p-6 overflow-y-auto max-h-[60vh]">
                    <div id="recipe-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        <!-- Recipes will be loaded here -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Success/Error Messages -->
    <div id="message-toast" class="fixed top-4 right-4 z-50 hidden">
        <div class="bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg flex items-center gap-3">
            <i class="fas fa-check-circle"></i>
            <span id="message-text">Recette ajoutée avec succès !</span>
        </div>
    </div>
    {# Page Header #}
    <div class="bg-white border-b border-gray-200 shadow-sm dark:bg-gray-800 dark:border-gray-700">
        <div class="px-4 py-6 mx-auto max-w-7xl sm:px-6 lg:px-8">
            <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                <div>
                    <h1 class="flex items-center gap-3 text-2xl font-bold text-gray-900 dark:text-white">
                        <i class="text-3xl fas fa-calendar-alt text-wellcare-500"></i>
                        Planificateur de repas
                    </h1>
                    <p class="mt-1 text-gray-600 dark:text-gray-400">Planifiez vos repas équilibrés pour la semaine</p>
                </div>
            </div>

            {# Sub Navigation #}
            <div class="px-4 py-4 mx-auto max-w-7xl sm:px-6 lg:px-8">
                <nav class="flex space-x-8">
                    <a href="{{ path('nutrition_dashboard') }}" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 border-b-2 border-transparent px-1 py-2 text-sm font-medium">
                        <i class="mr-2 fas fa-home"></i>Tableau de bord
                    </a>
                    <a href="{{ path('nutrition_food_diary') }}" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 border-b-2 border-transparent px-1 py-2 text-sm font-medium">
                        <i class="mr-2 fas fa-book"></i>Journal alimentaire
                    </a>
                    <a href="{{ path('nutrition_meal_planner') }}" class="text-wellcare-600 dark:text-wellcare-400 border-b-2 border-wellcare-600 dark:border-wellcare-400 px-1 py-2 text-sm font-medium">
                        <i class="mr-2 fas fa-calendar-alt"></i>Planificateur
                    </a>
                    <a href="{{ path('nutrition_recipes') }}" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 border-b-2 border-transparent px-1 py-2 text-sm font-medium">
                        <i class="mr-2 fas fa-utensils"></i>Recettes
                    </a>
                    <a href="{{ path('nutrition_goals') }}" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 border-b-2 border-transparent px-1 py-2 text-sm font-medium">
                        <i class="mr-2 fas fa-bullseye"></i>Objectifs
                    </a>
                    <a href="{{ path('nutrition_progress') }}" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 border-b-2 border-transparent px-1 py-2 text-sm font-medium">
                        <i class="mr-2 fas fa-chart-line"></i>Progrès
                    </a>
                </nav>
            </div>
        </div>
    </div>

    <main class="px-4 py-8 mx-auto max-w-7xl sm:px-6 lg:px-8">

        {# Week Navigation and Actions #}
        <div class="flex flex-col gap-6 mb-8 lg:flex-row lg:items-center lg:justify-between">
            {# Week Navigation #}
            <div class="flex items-center gap-3">
                <a href="{{ path('nutrition_meal_planner', {'weekStart': weekStart|date_modify('-7 days')|date('Y-m-d')}) }}"
                   class="p-3 transition-colors border border-gray-300 rounded-lg dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 hover:shadow-md">
                    <i class="text-gray-600 fas fa-chevron-left dark:text-gray-300"></i>
                </a>
                <div class="px-6 py-3 font-medium text-center text-white rounded-lg bg-wellcare-500 dark:bg-wellcare-600 min-w-[200px]">
                    {{ weekRange }}
                </div>
                <a href="{{ path('nutrition_meal_planner', {'weekStart': weekStart|date_modify('+7 days')|date('Y-m-d')}) }}"
                   class="p-3 transition-colors border border-gray-300 rounded-lg dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 hover:shadow-md">
                    <i class="text-gray-600 fas fa-chevron-right dark:text-gray-300"></i>
                </a>
                <a href="{{ path('nutrition_meal_planner') }}"
                   class="px-4 py-3 text-gray-700 transition-colors border border-gray-300 rounded-lg dark:border-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 hover:shadow-md">
                    Aujourd'hui
                </a>
            </div>

            {# Quick Actions #}
            <div class="flex flex-wrap gap-3">
                <button onclick="document.getElementById('recipe-modal').classList.remove('hidden')"
                        class="px-4 py-2 font-medium text-white transition-colors rounded-lg bg-wellcare-500 hover:bg-wellcare-600 hover:shadow-md">
                    <i class="mr-2 fas fa-plus"></i>Ajouter une recette
                </button>
                <form method="post" class="inline">
                    <input type="hidden" name="action" value="clear_week">
                    <button type="submit" onclick="return confirm('Êtes-vous sûr de vouloir effacer toute la semaine ?')"
                            class="px-4 py-2 text-red-600 transition-colors border border-red-300 rounded-lg dark:border-red-700 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 hover:shadow-md">
                        <i class="mr-2 fas fa-trash"></i>Effacer la semaine
                    </button>
                </form>
            </div>
        </div>

        {# Nutrition Summary #}
        <div class="p-4 mb-6 bg-white shadow-lg dark:bg-gray-800 rounded-2xl">
            <div class="flex flex-wrap items-center justify-between gap-4">
                <div class="flex items-center gap-4">
                    <div class="text-center">
                        <p class="text-2xl font-bold text-wellcare-500">{{ weeklyStats.calories }}</p>
                        <p class="text-xs text-gray-500">Calories/semaine</p>
                    </div>
                    <div class="w-px h-8 bg-gray-200 dark:bg-gray-700"></div>
                    <div class="text-center">
                        <p class="text-2xl font-bold text-wellcare-500">{{ weeklyStats.avgCalories }}</p>
                        <p class="text-xs text-gray-500">Moyenne/jour</p>
                    </div>
                    <div class="w-px h-8 bg-gray-200 dark:bg-gray-700"></div>
                    <div class="text-center">
                        <p class="text-lg font-semibold text-wellcare-500">{{ weeklyStats.protein }}g</p>
                        <p class="text-xs text-gray-500">Protéines/jour</p>
                    </div>
                    <div class="w-px h-8 bg-gray-200 dark:bg-gray-700"></div>
                    <div class="text-center">
                        <p class="text-lg font-semibold text-wellcare-500">{{ weeklyStats.carbs }}g</p>
                        <p class="text-xs text-gray-500">Glucides/jour</p>
                    </div>
                    <div class="w-px h-8 bg-gray-200 dark:bg-gray-700"></div>
                    <div class="text-center">
                        <p class="text-lg font-semibold text-wellcare-500">{{ weeklyStats.fats }}g</p>
                        <p class="text-xs text-gray-500">Lipides/jour</p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <span class="px-3 py-1 text-sm font-medium rounded-full bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300">
                        Équilibré
                    </span>
                </div>
            </div>
        </div>

        {# Weekly Calendar #}
        <div class="p-6 mb-6 bg-white shadow-lg dark:bg-gray-800 rounded-2xl">
            <div class="grid grid-cols-7 gap-4">
                {# Day Headers #}
                {% set days = ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'] %}
                {% set dayNames = ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
                {% for i in 0..6 %}
                <div class="text-center">
                    <p class="font-semibold text-gray-900 dark:text-white">{{ dayNames[i] }}</p>
                    <p class="text-sm text-gray-500">{{ weekStart|date_modify("+" ~ i ~ " days")|date('d/m') }}</p>
                </div>
                {% endfor %}

                {# Day Columns #}
                {% for day in days %}
                <div class="border border-gray-200 dark:border-gray-600 rounded-xl p-4 min-h-[400px] bg-gray-50 dark:bg-gradient-to-br dark:from-gray-800 dark:to-gray-700 hover:shadow-md transition-shadow">
                    {# Meal Slots #}
                    <div class="space-y-4">
                        {# Breakfast #}
                        <div class="meal-slot">
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex items-center gap-2">
                                    <i class="fas fa-sun text-orange-500 text-sm"></i>
                                    <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">Petit-déjeuner</span>
                                </div>
                                <form method="post" class="inline">
                                    <input type="hidden" name="action" value="add_meal">
                                    <input type="hidden" name="day" value="{{ day }}">
                                    <input type="hidden" name="meal_type" value="breakfast">
                                    <select name="food_item_id" class="text-xs border border-gray-300 rounded-md px-2 py-1 dark:border-gray-600 dark:bg-gray-700 focus:ring-2 focus:ring-wellcare-500 focus:border-transparent">
                                        <option value="">Ajouter...</option>
                                        {% for recipe in recipes %}
                                            {% if recipe.mealType == 'breakfast' or recipe.mealType == 'snacks' %}
                                                <option value="{{ recipe.id }}">{{ recipe.name }} ({{ recipe.calories }} cal)</option>
                                            {% endif %}
                                        {% endfor %}
                                    </select>
                                    <button type="submit" class="ml-1 text-xs bg-wellcare-500 hover:bg-wellcare-600 text-white px-2 py-1 rounded-md transition-colors">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </form>
                            </div>
                            <div class="space-y-2">
                                {% for meal in weekPlan[day]['breakfast'] %}
                                <div class="flex items-center justify-between bg-white dark:bg-gray-700 p-3 rounded-lg border border-gray-100 dark:border-gray-600 hover:shadow-sm transition-shadow">
                                    <div class="flex items-center gap-2">
                                        <i class="fas fa-utensils text-orange-400 text-xs"></i>
                                        <span class="font-medium text-gray-900 dark:text-white">{{ meal.name }}</span>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <span class="text-xs font-semibold text-wellcare-600 bg-wellcare-50 dark:bg-wellcare-900/30 px-2 py-1 rounded">{{ meal.calories }} cal</span>
                                        <form method="post" class="inline">
                                            <input type="hidden" name="action" value="remove_meal">
                                            <input type="hidden" name="food_plan_id" value="{{ meal.plan_id }}">
                                            <input type="hidden" name="food_item_id" value="{{ meal.id }}">
                                            <button type="submit" class="text-red-500 hover:text-red-700 hover:bg-red-50 dark:hover:bg-red-900/20 p-1 rounded transition-colors">
                                                <i class="fas fa-times text-xs"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                                {% endfor %}
                                {% if weekPlan[day]['breakfast'] is empty %}
                                <div class="text-center py-4 text-gray-400 dark:text-gray-500">
                                    <i class="fas fa-coffee text-xl mb-1 text-gray-300 dark:text-gray-600"></i>
                                    <p class="text-xs text-gray-400 dark:text-gray-500">Aucun repas prévu</p>
                                </div>
                                {% endif %}
                            </div>
                        </div>

                        {# Lunch #}
                        <div class="meal-slot">
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex items-center gap-2">
                                    <i class="fas fa-utensils text-green-500 text-sm"></i>
                                    <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">Déjeuner</span>
                                </div>
                                <form method="post" class="inline">
                                    <input type="hidden" name="action" value="add_meal">
                                    <input type="hidden" name="day" value="{{ day }}">
                                    <input type="hidden" name="meal_type" value="lunch">
                                    <select name="food_item_id" class="text-xs border border-gray-300 rounded-md px-2 py-1 dark:border-gray-600 dark:bg-gray-700 focus:ring-2 focus:ring-wellcare-500 focus:border-transparent">
                                        <option value="">Ajouter...</option>
                                        {% for recipe in recipes %}
                                            {% if recipe.mealType == 'lunch' or recipe.mealType == 'snacks' %}
                                                <option value="{{ recipe.id }}">{{ recipe.name }} ({{ recipe.calories }} cal)</option>
                                            {% endif %}
                                        {% endfor %}
                                    </select>
                                    <button type="submit" class="ml-1 text-xs bg-wellcare-500 hover:bg-wellcare-600 text-white px-2 py-1 rounded-md transition-colors">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </form>
                            </div>
                            <div class="space-y-2">
                                {% for meal in weekPlan[day]['lunch'] %}
                                <div class="flex items-center justify-between bg-white dark:bg-gray-700 p-3 rounded-lg border border-gray-100 dark:border-gray-600 hover:shadow-sm transition-shadow">
                                    <div class="flex items-center gap-2">
                                        <i class="fas fa-utensils text-green-400 text-xs"></i>
                                        <span class="font-medium text-gray-900 dark:text-white">{{ meal.name }}</span>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <span class="text-xs font-semibold text-wellcare-600 bg-wellcare-50 dark:bg-wellcare-900/30 px-2 py-1 rounded">{{ meal.calories }} cal</span>
                                        <form method="post" class="inline">
                                            <input type="hidden" name="action" value="remove_meal">
                                            <input type="hidden" name="food_plan_id" value="{{ meal.plan_id }}">
                                            <input type="hidden" name="food_item_id" value="{{ meal.id }}">
                                            <button type="submit" class="text-red-500 hover:text-red-700 hover:bg-red-50 dark:hover:bg-red-900/20 p-1 rounded transition-colors">
                                                <i class="fas fa-times text-xs"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                                {% endfor %}
                                {% if weekPlan[day]['lunch'] is empty %}
                                <div class="text-center py-4 text-gray-400 dark:text-gray-500">
                                    <i class="fas fa-utensils text-xl mb-1 text-gray-300 dark:text-gray-600"></i>
                                    <p class="text-xs text-gray-400 dark:text-gray-500">Aucun repas prévu</p>
                                </div>
                                {% endif %}
                            </div>
                        </div>

                        {# Dinner #}
                        <div class="meal-slot">
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex items-center gap-2">
                                    <i class="fas fa-moon text-blue-500 text-sm"></i>
                                    <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">Dîner</span>
                                </div>
                                <form method="post" class="inline">
                                    <input type="hidden" name="action" value="add_meal">
                                    <input type="hidden" name="day" value="{{ day }}">
                                    <input type="hidden" name="meal_type" value="dinner">
                                    <select name="food_item_id" class="text-xs border border-gray-300 rounded-md px-2 py-1 dark:border-gray-600 dark:bg-gray-700 focus:ring-2 focus:ring-wellcare-500 focus:border-transparent">
                                        <option value="">Ajouter...</option>
                                        {% for recipe in recipes %}
                                            {% if recipe.mealType == 'dinner' or recipe.mealType == 'snacks' %}
                                                <option value="{{ recipe.id }}">{{ recipe.name }} ({{ recipe.calories }} cal)</option>
                                            {% endif %}
                                        {% endfor %}
                                    </select>
                                    <button type="submit" class="ml-1 text-xs bg-wellcare-500 hover:bg-wellcare-600 text-white px-2 py-1 rounded-md transition-colors">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </form>
                            </div>
                            <div class="space-y-2">
                                {% for meal in weekPlan[day]['dinner'] %}
                                <div class="flex items-center justify-between bg-white dark:bg-gray-700 p-3 rounded-lg border border-gray-100 dark:border-gray-600 hover:shadow-sm transition-shadow">
                                    <div class="flex items-center gap-2">
                                        <i class="fas fa-utensils text-blue-400 text-xs"></i>
                                        <span class="font-medium text-gray-900 dark:text-white">{{ meal.name }}</span>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <span class="text-xs font-semibold text-wellcare-600 bg-wellcare-50 dark:bg-wellcare-900/30 px-2 py-1 rounded">{{ meal.calories }} cal</span>
                                        <form method="post" class="inline">
                                            <input type="hidden" name="action" value="remove_meal">
                                            <input type="hidden" name="food_plan_id" value="{{ meal.plan_id }}">
                                            <input type="hidden" name="food_item_id" value="{{ meal.id }}">
                                            <button type="submit" class="text-red-500 hover:text-red-700 hover:bg-red-50 dark:hover:bg-red-900/20 p-1 rounded transition-colors">
                                                <i class="fas fa-times text-xs"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                                {% endfor %}
                                {% if weekPlan[day]['dinner'] is empty %}
                                <div class="text-center py-4 text-gray-400 dark:text-gray-500">
                                    <i class="fas fa-utensils text-xl mb-1 text-gray-300 dark:text-gray-600"></i>
                                    <p class="text-xs text-gray-400 dark:text-gray-500">Aucun repas prévu</p>
                                </div>
                                {% endif %}
                            </div>
                        </div>

                        {# Snacks #}
                        <div class="meal-slot">
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex items-center gap-2">
                                    <i class="fas fa-cookie-bite text-purple-500 text-sm"></i>
                                    <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">Collations</span>
                                </div>
                                <form method="post" class="inline">
                                    <input type="hidden" name="action" value="add_meal">
                                    <input type="hidden" name="day" value="{{ day }}">
                                    <input type="hidden" name="meal_type" value="snacks">
                                    <select name="food_item_id" class="text-xs border border-gray-300 rounded-md px-2 py-1 dark:border-gray-600 dark:bg-gray-700 focus:ring-2 focus:ring-wellcare-500 focus:border-transparent">
                                        <option value="">Ajouter...</option>
                                        {% for recipe in recipes %}
                                            <option value="{{ recipe.id }}">{{ recipe.name }} ({{ recipe.calories }} cal)</option>
                                        {% endfor %}
                                    </select>
                                    <button type="submit" class="ml-1 text-xs bg-wellcare-500 hover:bg-wellcare-600 text-white px-2 py-1 rounded-md transition-colors">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </form>
                            </div>
                            <div class="space-y-2">
                                {% for meal in weekPlan[day]['snacks'] %}
                                <div class="flex items-center justify-between bg-white dark:bg-gray-700 p-3 rounded-lg border border-gray-100 dark:border-gray-600 hover:shadow-sm transition-shadow">
                                    <div class="flex items-center gap-2">
                                        <i class="fas fa-cookie-bite text-purple-400 text-xs"></i>
                                        <span class="font-medium text-gray-900 dark:text-white">{{ meal.name }}</span>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <span class="text-xs font-semibold text-wellcare-600 bg-wellcare-50 dark:bg-wellcare-900/30 px-2 py-1 rounded">{{ meal.calories }} cal</span>
                                        <form method="post" class="inline">
                                            <input type="hidden" name="action" value="remove_meal">
                                            <input type="hidden" name="food_plan_id" value="{{ meal.plan_id }}">
                                            <input type="hidden" name="food_item_id" value="{{ meal.id }}">
                                            <button type="submit" class="text-red-500 hover:text-red-700 hover:bg-red-50 dark:hover:bg-red-900/20 p-1 rounded transition-colors">
                                                <i class="fas fa-times text-xs"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                                {% endfor %}
                                {% if weekPlan[day]['snacks'] is empty %}
                                <div class="text-center py-4 text-gray-400 dark:text-gray-500">
                                    <i class="fas fa-cookie-bite text-xl mb-1 text-gray-300 dark:text-gray-600"></i>
                                    <p class="text-xs text-gray-400 dark:text-gray-500">Aucune collation prévue</p>
                                </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>

        {# Recipe Library #}
        <div class="p-6 bg-white shadow-lg dark:bg-gray-800 rounded-2xl">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Bibliothèque de recettes</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {% for recipe in recipes %}
                <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4 hover:shadow-md transition-shadow">
                    <div class="flex items-start justify-between mb-2">
                        <h4 class="font-medium text-gray-900 dark:text-white">{{ recipe.name }}</h4>
                        <span class="text-sm text-gray-500">{{ recipe.calories }} cal</span>
                    </div>
                    <div class="text-sm text-gray-600 dark:text-gray-400 mb-2">
                        P: {{ recipe.proteins }}g | G: {{ recipe.carbs }}g | L: {{ recipe.fats }}g
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="px-2 py-1 text-xs rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
                            {{ recipe.mealType }}
                        </span>
                        <span class="px-2 py-1 text-xs rounded-full bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200">
                            {{ recipe.diet }}
                        </span>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

<script>
// Meal Planner JavaScript functionality
document.addEventListener('DOMContentLoaded', function() {
    initializeMealPlanner();
});

function initializeMealPlanner() {
    // Initialize recipe modal
    initializeRecipeModal();

    // Initialize drag and drop
    initializeDragAndDrop();

    // Initialize search functionality
    initializeSearch();

    // Initialize form submissions
    initializeFormSubmissions();
}

function initializeRecipeModal() {
    const modal = document.getElementById('recipe-modal');
    const searchInput = document.getElementById('recipe-search');
    const recipeList = document.getElementById('recipe-list');

    // Load recipes
    loadRecipes();

    // Search functionality
    searchInput.addEventListener('input', function() {
        const query = this.value.toLowerCase();
        const recipeCards = recipeList.querySelectorAll('.recipe-card');

        recipeCards.forEach(card => {
            const name = card.querySelector('h4').textContent.toLowerCase();
            const visible = name.includes(query);
            card.style.display = visible ? 'block' : 'none';
        });
    });
}

function loadRecipes() {
    const recipeList = document.getElementById('recipe-list');

    // Sample recipes - in real app, this would come from API
    const recipes = {{ recipes|json_encode|raw }};

    recipeList.innerHTML = recipes.map(recipe => `
        <div class="recipe-card bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4 hover:shadow-md transition-shadow cursor-pointer"
             onclick="selectRecipe(${recipe.id}, '${recipe.name}', '${recipe.mealType}')">
            <div class="flex items-start justify-between mb-2">
                <h4 class="font-medium text-gray-900 dark:text-white">${recipe.name}</h4>
                <span class="text-sm text-gray-500">${recipe.calories} cal</span>
            </div>
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-2">
                P: ${recipe.proteins}g | G: ${recipe.carbs}g | L: ${recipe.fats}g
            </div>
            <div class="flex items-center gap-2">
                <span class="px-2 py-1 text-xs rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
                    ${recipe.mealType}
                </span>
                <span class="px-2 py-1 text-xs rounded-full bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200">
                    ${recipe.diet}
                </span>
            </div>
        </div>
    `).join('');
}

function selectRecipe(recipeId, recipeName, mealType) {
    // Close modal
    closeRecipeModal();

    // Show success message
    showToast('Recette sélectionnée ! Utilisez le menu déroulant pour l\'ajouter à un repas.');

    // Update all select dropdowns to include this recipe
    const selects = document.querySelectorAll('select[name="food_item_id"]');
    selects.forEach(select => {
        const option = document.createElement('option');
        option.value = recipeId;
        option.textContent = `${recipeName} (${recipeId} cal)`;
        select.appendChild(option);
    });
}

function closeRecipeModal() {
    document.getElementById('recipe-modal').classList.add('hidden');
}

function initializeDragAndDrop() {
    // Add drag and drop functionality for meal items
    const mealItems = document.querySelectorAll('.meal-item');

    mealItems.forEach(item => {
        item.draggable = true;
        item.addEventListener('dragstart', handleDragStart);
        item.addEventListener('dragend', handleDragEnd);
    });

    const mealSlots = document.querySelectorAll('.meal-slot .space-y-2');
    mealSlots.forEach(slot => {
        slot.addEventListener('dragover', handleDragOver);
        slot.addEventListener('drop', handleDrop);
    });
}

function handleDragStart(e) {
    e.dataTransfer.setData('text/plain', e.target.dataset.mealId);
    e.target.classList.add('opacity-50');
}

function handleDragEnd(e) {
    e.target.classList.remove('opacity-50');
}

function handleDragOver(e) {
    e.preventDefault();
    e.currentTarget.classList.add('bg-blue-50', 'dark:bg-blue-900/20');
}

function handleDrop(e) {
    e.preventDefault();
    e.currentTarget.classList.remove('bg-blue-50', 'dark:bg-blue-900/20');

    const mealId = e.dataTransfer.getData('text/plain');
    const mealItem = document.querySelector(`[data-meal-id="${mealId}"]`);

    if (mealItem && e.currentTarget !== mealItem.parentElement) {
        // Move meal item to new slot
        e.currentTarget.appendChild(mealItem);

        // Update meal type in backend
        updateMealType(mealId, getMealTypeFromSlot(e.currentTarget));
    }
}

function getMealTypeFromSlot(slotElement) {
    const mealSlot = slotElement.closest('.meal-slot');
    if (mealSlot.querySelector('.fa-sun')) return 'breakfast';
    if (mealSlot.querySelector('.fa-utensils')) return 'lunch';
    if (mealSlot.querySelector('.fa-moon')) return 'dinner';
    if (mealSlot.querySelector('.fa-cookie-bite')) return 'snacks';
    return 'snacks';
}

function updateMealType(mealId, newMealType) {
    // AJAX call to update meal type
    fetch(`/nutrition/api/meal-planner/update-meal-type`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            mealId: mealId,
            mealType: newMealType
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showToast('Repas déplacé avec succès !');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showToast('Erreur lors du déplacement du repas.', 'error');
    });
}

function initializeSearch() {
    // Add search functionality for food items
    const searchInputs = document.querySelectorAll('.food-search');

    searchInputs.forEach(input => {
        input.addEventListener('input', function() {
            const query = this.value.toLowerCase();
            const select = this.nextElementSibling;

            if (select && select.tagName === 'SELECT') {
                const options = select.querySelectorAll('option');

                options.forEach(option => {
                    if (option.value === '') return; // Skip empty option

                    const visible = option.textContent.toLowerCase().includes(query);
                    option.style.display = visible ? 'block' : 'none';
                });
            }
        });
    });
}

function initializeFormSubmissions() {
    // Handle form submissions with AJAX
    const forms = document.querySelectorAll('form[method="post"]');

    forms.forEach(form => {
        form.addEventListener('submit', function(e) {
            e.preventDefault();

            const formData = new FormData(this);

            fetch(this.action, {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (response.ok) {
                    // Reload the page content or update specific sections
                    location.reload();
                } else {
                    showToast('Erreur lors de la sauvegarde.', 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showToast('Erreur lors de la sauvegarde.', 'error');
            });
        });
    });
}

function showToast(message, type = 'success') {
    const toast = document.getElementById('message-toast');
    const messageText = document.getElementById('message-text');

    messageText.textContent = message;

    if (type === 'error') {
        toast.classList.remove('bg-green-500');
        toast.classList.add('bg-red-500');
    } else {
        toast.classList.remove('bg-red-500');
        toast.classList.add('bg-green-500');
    }

    toast.classList.remove('hidden');

    // Hide after 3 seconds
    setTimeout(() => {
        toast.classList.add('hidden');
    }, 3000);
}

// Keyboard shortcuts
document.addEventListener('keydown', function(e) {
    // Ctrl/Cmd + K to open recipe modal
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        document.getElementById('recipe-modal').classList.remove('hidden');
        document.getElementById('recipe-search').focus();
    }

    // Escape to close modal
    if (e.key === 'Escape') {
        closeRecipeModal();
    }
});

// Auto-save functionality (save every 30 seconds if changes were made)
let hasChanges = false;
setInterval(() => {
    if (hasChanges) {
        // Auto-save logic here
        console.log('Auto-saving...');
        hasChanges = false;
    }
}, 30000);

// Mark as changed when user interacts with forms
document.addEventListener('input', () => {
    hasChanges = true;
});
document.addEventListener('change', () => {
    hasChanges = true;
});
</script>
{% endblock %}
