{% extends 'base.html.twig' %}

{% block title %}GroceryItem{% endblock %}

{% block body %}
    <h1>GroceryItem</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ grocery_item.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ grocery_item.name }}</td>
            </tr>
            <tr>
                <th>Category</th>
                <td>{{ grocery_item.category }}</td>
            </tr>
            <tr>
                <th>Quantity</th>
                <td>{{ grocery_item.quantity }}</td>
            </tr>
            <tr>
                <th>Unit</th>
                <td>{{ grocery_item.unit }}</td>
            </tr>
            <tr>
                <th>Checked</th>
                <td>{{ grocery_item.checked ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>EstimatedPrice</th>
                <td>{{ grocery_item.estimatedPrice }}</td>
            </tr>
            <tr>
                <th>Position</th>
                <td>{{ grocery_item.position }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_grocery_item_index') }}">back to list</a>

    <a href="{{ path('app_grocery_item_edit', {'id': grocery_item.id}) }}">edit</a>

    {{ include('grocery_item/_delete_form.html.twig') }}
{% endblock %}
