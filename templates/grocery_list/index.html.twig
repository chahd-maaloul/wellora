{% extends 'base.html.twig' %}

{% block title %}GroceryList index{% endblock %}

{% block body %}
    <h1>GroceryList index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>CreatedAt</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for grocery_list in grocery_lists %}
            <tr>
                <td>{{ grocery_list.id }}</td>
                <td>{{ grocery_list.name }}</td>
                <td>{{ grocery_list.createdAt ? grocery_list.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_grocery_list_show', {'id': grocery_list.id}) }}">show</a>
                    <a href="{{ path('app_grocery_list_edit', {'id': grocery_list.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_grocery_list_new') }}">Create new</a>
{% endblock %}
