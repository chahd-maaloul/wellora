{% extends 'base.html.twig' %}

{% block title %}GroceryList{% endblock %}

{% block body %}
    <h1>GroceryList</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ grocery_list.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ grocery_list.name }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ grocery_list.createdAt ? grocery_list.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_grocery_list_index') }}">back to list</a>

    <a href="{{ path('app_grocery_list_edit', {'id': grocery_list.id}) }}">edit</a>

    {{ include('grocery_list/_delete_form.html.twig') }}
{% endblock %}
