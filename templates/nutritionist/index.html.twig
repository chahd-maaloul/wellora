{% extends 'base.html.twig' %}

{% block title %}Nutritionist index{% endblock %}

{% block body %}
    <h1>Nutritionist index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>NomNutritioniste</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for nutritionist in nutritionists %}
            <tr>
                <td>{{ nutritionist.id }}</td>
                <td>{{ nutritionist.nomNutritioniste }}</td>
                <td>
                    <a href="{{ path('app_nutritionist_show', {'id': nutritionist.id}) }}">show</a>
                    <a href="{{ path('app_nutritionist_edit', {'id': nutritionist.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_nutritionist_new') }}">Create new</a>
{% endblock %}
