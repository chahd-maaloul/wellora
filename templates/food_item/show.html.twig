{% extends 'base.html.twig' %}

{% block title %}FoodItem{% endblock %}

{% block body %}
    <h1>FoodItem</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ food_item.id }}</td>
            </tr>
            <tr>
                <th>NomItem</th>
                <td>{{ food_item.nomItem }}</td>
            </tr>
            <tr>
                <th>Calories</th>
                <td>{{ food_item.calories }}</td>
            </tr>
            <tr>
                <th>Protein</th>
                <td>{{ food_item.protein }}</td>
            </tr>
            <tr>
                <th>Fat</th>
                <td>{{ food_item.fat }}</td>
            </tr>
            <tr>
                <th>Carbs</th>
                <td>{{ food_item.carbs }}</td>
            </tr>
            <tr>
                <th>LoggedAt</th>
                <td>{{ food_item.loggedAt ? food_item.loggedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>MealType</th>
                <td>{{ food_item.mealType }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_food_item_index') }}">back to list</a>

    <a href="{{ path('app_food_item_edit', {'id': food_item.id}) }}">edit</a>

    {{ include('food_item/_delete_form.html.twig') }}
{% endblock %}
